# .env.example — committed template of the runtime secrets this project expects.
# Copy to .env and fill in real values:  cp .env.example .env
# The real .env is gitignored and MUST NEVER be committed (constitution §5).
# In CI, provide these as GitHub Actions secrets — not in the repo.

# --- ai/ — model providers ------------------------------------------------
# Anthropic / Claude is the default stack for AI agent coding here.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI — only if the ai/ layer uses the OpenAI SDK.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- backend/ — data access -----------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
